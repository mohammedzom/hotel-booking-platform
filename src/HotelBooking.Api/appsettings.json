{
  "ConnectionStrings": {
    "DefaultConnection": "Server=PROGRAMMER;Database=HotelBooking;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "JWT": {
    "Secret": "",
    "Issuer": "HotelBookingApi",
    "Audience": "HotelBookingClient",
    "ExpiryHours": 24
  },
  "BookingSettings": {
    "CheckoutHoldMinutes": 10,
    "TaxRate": 0.15,
    "CancellationFreeHours": 24,
    "CancellationFeePercent": 0.30,
    "MaxAdvanceBookingDays": 365
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "Swagger": {
    "Enabled": false
  },

  "RefreshToken": {
    "ExpiryDays": 7,
    "TokenBytes": 64
  }
}